<header>
	<nav class="navbar navbar-expand-lg">
		<div class="container-fluid px-4 logo">
			<a class="navbar-brand cp-brand mb-0" href="{{ path('app_home') }}"><img src="{{ asset('images/logo_catpuccino.svg') }}" alt="Logo Catpuccino">
			</a>
			<button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarToggleExternalContent" aria-controls="navbarToggleExternalContent" aria-expanded="false" aria-label="Toggle navigation">
				<span class="navbar-toggler-icon"></span>
			</button>
			<div class="collapse navbar-collapse" id="navbarToggleExternalContent">
				<ul class="navbar-nav mx-auto mb-2 mb-lg-0 gap-lg-3">
					{% set currentRoute = app.request.attributes.get('_route') %}
					<li class="nav-item">
						<a class="nav-link cp-nav-link {{ currentRoute == 'app_home' ? 'active' }}" href="{{ path('app_home') }}">Accueil</a>
					</li>
					<li class="nav-item">
						<a class="nav-link cp-nav-link {{ currentRoute == 'app_product_index' ? 'active' }}" href="{{ path('app_product_index') }}">Notre carte</a>
					</li>
					<li class="nav-item">
						<a class="nav-link cp-nav-link {{ currentRoute == 'app_cat_index' ? 'active' }}" href="{{ path('app_cat_index') }}">Nos chats</a>
					</li>
					<li class="nav-item">
						<a class="nav-link cp-nav-link {{ currentRoute == 'app_reservation_index' ? 'active' }}" href="{{ path('app_reservation_index') }}">Réserver</a>
					</li>
					{% if app.user %}
						<li class="nav-item">
							<a href="{{ path('app_dashboard') }}" class="btn btn-primary btnUserConnexion">Mon espace</a>
						</li>
					{% endif %}
				</ul>
				<div class="d-flex gap-2 btnUser">
					{% if app.user %}
						<span class="navbar-text me-2 align-self-center">
							Bonjour
							{{ app.user.firstname }}
						</span>
						<a href="{{ path('app_logout') }}" class="btn btn-outline-secondary btnUserSignUp">Se déconnecter</a>
					{% else %}
						<a href="{{ path('app_register') }}" class="btn btn-primary btnUserConnexion">S'inscrire</a>
						<a href="{{ path('app_login') }}" class="btn btn-outline-secondary btnUserSignUp">Connexion</a>
					{% endif %}
				</div>
			</div>
		</div>
	</nav>
</header>
