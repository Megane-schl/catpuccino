<div{{attributes}}>
	<div class="modal fade" id="{{ this.id }}" tabindex="-1" aria-labelledby="{{ this.id }}-label" aria-hidden="true">
		<div class="modal-dialog">
			<div class="modal-content">
				<div class="modal-header">
					<h5 class="modal-title" id="{{ this.id }}-label">{{ this.title }}</h5>
					<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
				</div>
				<div class="modal-body">
					{{ this.message }}
				</div>
				<div class="modal-footer">
					<button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Annuler</button>
					<form method="post" action="{{ this.action }}" class="d-inline-block">
						<input type="hidden" name="_csrf_token" value="{{ csrf_token(this.token) }}">
						<button type="submit" class="btn btn-danger">Confirmer</button>
					</form>
				</div>
			</div>
		</div>
	</div>
</div>
