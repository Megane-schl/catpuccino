<div class="col">
	<div class="card h-100 card-product-custom shadow-sm">

		<div class="position-relative img-wrapper">
			<img src="{{ asset('uploads/products/' ~ this.img) }}" class="card-img-top" alt="{{ this.name }}">
			<span class="position-absolute top-0 end-0 m-3 badge rounded-pill badge-price shadow-sm">
				{{ this.price }}€
			</span>
		</div>

		<div class="card-body d-flex flex-column text-center">

			<div class="d-flex flex-wrap justify-content-center gap-2 mb-3">
				<span class="badge rounded-pill badge-custom">{{ this.category }}</span>
				{% if this.seasonName %} 
					<span class="badge rounded-pill badge-custom badge-status">
						{{ this.seasonName }}</span>
				{% endif %}
			</div>

			<h5 class="card-title-product mt-2 fw-bold">{{ this.name }}</h5>

			<div class="mt-3">
				<a href="{{ path('app_product_show', { id: this.id }) }}" class="btn btn-custom w-100 rounded-pill py-2">
					Voir les détails
				</a>
			</div>
			{% if is_granted('ROLE_MODO') %}
				<div class="d-flex justify-content-center gap-2 mt-3">
					<twig:BootstrapButton type="primary" link="{{ path('app_product_update', { id: this.id }) }}" size="sm" text="Modifier"/>
					<button type="button" class="btn btn-outline-danger btn-sm" data-bs-toggle="modal" data-bs-target="#deleteModal-{{ this.id }}">
						Supprimer
					</button>
					<twig:BootstrapModal id="deleteModal-{{ this.id }}" title="Avertissement" 
					message="Êtes-vous sûr de vouloir supprimer le produit {{ this.name }} ?" 
					action="{{ path('app_product_delete', { id: this.id } ) }}" token="delete-product"/>
				</div>
			{% endif %}
		</div>
	</div>
</div>
