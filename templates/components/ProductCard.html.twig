<div{{attributes}}>
	<div class="card h-100 cp-card">
		<img src="{{ this.img }}" class="card-img-top" alt="{{ this.name }}">
		<div class="card-body">
			<h5 class="card-title">{{ this.name }}</h5>
			<p class="card-text">{{ this.price }}
				€</p>
			<div class="mt-3">
				{% for btn in this.actions %}
					<twig:BootstrapButton class="d-inline-block" text="{{ btn.label }}" :type="btn.type" link="{{ btn.link }}"/>
				{% endfor %}
			</div>
		</div>
	</div>
</div>
