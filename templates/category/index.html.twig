{% extends 'base.html.twig' %}

{% block title %}Gestion des catégories - Catpuccino
{% endblock %}

{% block body %}

	<section class="container my-5">
		<h1 class="mb-5 text-center">Gestion des catégories</h1>
		<div class="d-flex justify-content-end align-items-center my-5">
			<twig:BootstrapButton type="success" link="{{ path('app_category_create') }}" text="+ Ajouter une catégorie"/>
		</div>

		<table class="table table-hover table-borderless align-middle shadow-sm">
			<thead class="table-dark">
				<tr class="text-center">
					<th scope="col">Nom</th>
					<th scope="col">Actions</th>
				</tr>
			</thead>
			<tbody>
				{% for category in categoryList %}
					<tr>
						<td class="fw-bold text-center">{{ category.name }}</td>
						<td class="text-center">
							<div class="d-flex justify-content-center gap-2">
								<twig:BootstrapButton
								type="primary" link="{{ path('app_category_update', { id: category.id }) }}" size="sm" text="Modifier" :outlined="true"/>
							{# <button type="button" class="btn btn-outline-danger btn-sm" data-bs-toggle="modal" data-bs-target="#deleteModal-{{ category.id }}">
																Supprimer
															</button>
															<twig:BootstrapModal id="deleteModal-{{ category.id }}" title="Avertissement" message="Êtes-vous sûr de vouloir supprimer la catégorie {{ category.name }} ?" action="{{ path('app_category_delete', { id: category.id } ) }}" token="delete-category"/> #}
							</div>
						</td>
					</tr>
				{% endfor %}
			</tbody>
		</table>
	</section>
{% endblock %}
