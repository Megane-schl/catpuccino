{% extends 'base.html.twig' %}

{% block title %}
	{{ product.name }}
	- Catpuccino
{% endblock %}

{% block body %}
	<section class="container py-5">
		<div class="row justify-content-center">
			<div class="col-lg-10">

				<a href="{{ path('app_product_index') }}" class="btn btn-outline-dark rounded-pill mb-4">
					Retour au menu
				</a>

				<div class="card border-0 rounded-4 overflow-hidden shadow-sm">
					<div class="row g-0 align-items-stretch">
						<div class="col-md-6 d-flex align-items-center justify-content-center img-product">
							<img src="{{ asset('uploads/products/' ~ (product.img ?? 'default.png')) }}" alt="{{ product.name }}" class="img-fluid p-4">
						</div>

						<div class="col-md-6 p-4 p-lg-5 d-flex flex-column justify-content-center">
							<span class="badge rounded-pill text-white mb-2 align-self-start badge-product-category">{{ product.category.name }}</span>
							{% if product.seasonName %}
								<span class="badge rounded-pill product-season-name mb-2 align-self-start">{{ product.seasonName }}</span>
							{% endif %}

							<h1 class="fw-bold mb-2">{{ product.name }}</h1>

							{% if product.vegan or product.glutenFree or product.lactoseFree %}
								<div class="d-flex flex-wrap gap-2 mb-3">
									{% if product.vegan %}
										<span class="badge rounded-pill badge-veg-glut">Vegan</span>
									{% endif %}
									{% if product.glutenFree %}
										<span class="badge rounded-pill badge-veg-glut">Sans gluten</span>
									{% endif %}
									{% if product.lactoseFree %}
										<span class="badge rounded-pill badge-veg-glut">Sans lactose</span>
									{% endif %}
								</div>
							{% endif %}

							<p class="fw-bold mb-4 product-price">{{ product.price }}
								€</p>
							<p class="text-muted mb-4">{{ product.description }}</p>

							<div class="mb-4">
								<p class="text-muted small mb-2 text-uppercase">Composition</p>
								<div class="d-flex flex-wrap gap-2">
									{% for ingredient in product.ingredients %}
										<span class="badge rounded-pill product-badge-ingredient fw-semibold">{{ ingredient.name }}</span>
									{% endfor %}
								</div>
							</div>

							{% if allergenList|length > 0 %}
								<div class="mb-4">
									<p class="text-muted small mb-2 text-uppercase">Allergènes</p>
									<div class="d-flex flex-wrap gap-2">
										{% for allergen in allergenList %}
											<span class="badge rounded-pill product-badge-allergen">{{ allergen.name }}</span>
										{% endfor %}
									</div>
								</div>
							{% endif %}

							{% if app.user %}
								{% for ingredient in product.ingredients %}
									{% for allergen in ingredient.allergen %}
										{% if allergen in app.user.allergen%}
											<div class="alert alert-warning">
												<twig:ux:icon name="si:alert-fill"/>
												Ce produit contient
												{{ allergen.name }}
												qui fait partie de vos allergènes.
											</div>
										{% endif %}
									{% endfor %}
								{% endfor %}
							{% endif %}

							{% if product.seasonName and product.periodStart and product.periodEnd %}
								<div class="p-3 rounded-3">
									<p class="mb-0 small">
										<strong>Produit saisonnier</strong>
										- Disponible du
										{{ product.periodStart|date('d/m/Y') }}
										au
										{{ product.periodEnd|date('d/m/Y') }}
									</p>
								</div>
							{% endif %}
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>
{% endblock %}
