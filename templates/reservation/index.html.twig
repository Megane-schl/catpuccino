{% extends 'base.html.twig' %}

{% block title %}Réservation - Catpuccino
{% endblock %}

{% block body %}
	<main>
		<div class="reservation-linear">
			<div class="container">
				<section class="reservation-hero row align-items-center text-center text-lg-start">
					<div class="col-lg-6">
						<h1 class="fw-bold">Votre moment câlin</h1>
						<p class="lead">Un café, un chat, un instant de douceur. Venez partager une pause hors du temps avec nos petits compagnons.</p>
						<div class="mt-4">
							<a href="{{ path('app_reservation_create') }}" class="btn-reserve">Réserver votre créneau</a>
						</div>
					</div>
					<div class="col-lg-6 mt-4 mt-lg-0 d-flex justify-content-center gap-3">
						<img src="{{ asset('images/chat-catpuccino.png') }}" class="cat-circle" alt="Chat 1">
						<img src="{{ asset('images/black-cat-coffee.png') }}" class="cat-circle" alt="Café chat">
						<img src="{{ asset('images/chat-catpuccino2.png') }}" class="cat-circle" alt="Chat 2">
						
					</div>
				</section>
			</div>
		</div>

		<section class="rules-section container">
			<h2 class="text-center mb-5 fw-bold">Bien vivre au Catpuccino</h2>
			<div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4">

				<div class="col">
					<div class="rule-card">
						<div class="rule-icon"><twig:ux:icon name="token-branded:popcat"/></div>
						<h5>Hygiène</h5>
						<p>Merci de vous laver les mains à l'entrée. Nos chats sont sensibles, la propreté est leur priorité.</p>
					</div>
				</div>

				<div class="col">
					<div class="rule-card">
						<div class="rule-icon"><twig:ux:icon name="solar:cat-broken"/></div>
						<h5>Respect du sommeil</h5>
						<p>Un chat qui dort est un chat heureux. Merci de ne pas les réveiller, même pour une photo !</p>
					</div>
				</div>

				<div class="col">
					<div class="rule-card">
						<div class="rule-icon"><twig:ux:icon name="fluent-emoji-high-contrast:paw-prints"/></div>
						<h5>Douceur</h5>
						<p>Pas de cris, pas de courses. Laissez les chats venir vers vous quand ils en ont envie.</p>
					</div>
				</div>

				<div class="col">
					<div class="rule-card">
						<div class="rule-icon"><twig:ux:icon name="openmoji:hacker-cat"/></div>
						<h5>Photos</h5>
						<p>Nos amis ont les yeux très sensibles. Le flash est strictement interdit dans le salon.</p>
					</div>
				</div>

			</div>
		</section>
	</div>
</main>

{% endblock %}
