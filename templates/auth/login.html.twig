{% extends 'base.html.twig' %}

{% block title %}
	Connexion - Catpuccino
{% endblock %}

{% block body %}
	<twig:FormCard title="Bon retour parminou !" subtitle="Connectez-vous">

		{% if app.user %}
			<div class="mb-3">
				Vous êtes connecté en tant que
				{{ app.user.userIdentifier }},
				<a href="{{ logout_path() }}">Déconnexion</a>
			</div>
		{% endif %}

		{% if error %}
			<div class="alert alert-danger">
				Adresse e-mail ou mot de passe invalide
			</div>
		{% endif %}
		<form method="post">
			<div class="mb-3">
				<label for="username" class="mb-2">Adresse e-mail</label>
				<input type="email" value="{{ last_username }}" placeholder="exemple@gmail.fr" name="_username" id="username" class="form-control" autocomplete="email" required autofocus>
			</div>
			<div class="mb-3">
				<label for="password" class="mb-2">Mot de passe</label>
				<input type="password" placeholder="••••••••••" name="_password" id="password" class="form-control" autocomplete="current-password" required>
				<input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">
			</div>
			<!-- Remember me -->
			<div class="d-flex justify-content-between align-items-center mb-3">
				<div class="form-check">
					<input class="form-check-input" type="checkbox" name="_remember_me" id="_remember_me">
					<label for="_remember_me">Se souvenir de moi</label>
				</div>
				<!-- Forget password-->
				<a href="{{ path('app_forgot_password_request') }}" class="d-flex">Mot de passe oublié ?</a>
			</div>

			<!-- No account ?-->
			<button type="submit" class="btn btn-primary w-100">Se connecter</button>
		</form>
		<p class="text-center text-muted mt-4">
			Vous n'avez pas de compte ?
			<a href="{{ path('app_register') }}" class="fw-semibold">Inscrivez-vous</a>
		</p>
	</twig:FormCard>
</div></form>{% endblock %}
